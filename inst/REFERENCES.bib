@ARTICLE{HRM_RJournal,
  title     = "{HRM}: An {R} package for analysing high-dimensional
               multi-factor repeated measures",
  author    = "Happ, Martin and Harrar, Solomon,w and Bathke, Arne,c",
  abstract  = "High-dimensional longitudinal data pose a serious challenge for
               statistical inference as many test statistics cannot be computed
               for high-dimensional data, or they do not maintain the nominal
               type-I error rate, or have very low power. Therefore, it is
               necessary to derive new inference methods capable of dealing
               with high dimensionality, and to make them available to
               statistics practitioners. One such method is implemented in the
               package HRM described in this article. This new method uses a
               similar approach as the Welch-Satterthwaite t-test approximation
               and works very well for high-dimensional data as long as the
               data distribution is not too skewed or heavy-tailed. The package
               also provides a GUI to offer an easy way to apply the methods.",
  journal   = "R J.",
  publisher = "The R Foundation",
  volume    =  10,
  number    =  1,
  pages     = "534",
  year      =  2018,
  language  = "en"
}

