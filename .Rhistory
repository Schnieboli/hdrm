#' #library(Rcpp)
#'
#'
#' #' @export
Rcpp::cppFunction(' // etwa 10x schneller
double B3_cpp(NumericMatrix mat) {
int nrows = mat.nrow();
double total_sum = 0.0;
NumericVector row1;
NumericVector row2;
NumericVector row3;
double dp1;
double dp2;
double dp3;
for (int i = 0; i < nrows - 2; ++i) {
for (int j = i + 1; j < nrows - 1; ++j) {
for (int k = j + 1; k < nrows; ++k) {
row1 = mat(i, _);
row2 = mat(j, _);
row3 = mat(k, _);
dp1 = std::inner_product(row1.begin(), row1.end(), row2.begin(), 0.0);
dp2 = std::inner_product(row2.begin(), row2.end(), row3.begin(), 0.0);
dp3 = std::inner_product(row3.begin(), row3.end(), row1.begin(), 0.0);
total_sum += dp1 + dp2 + dp3;
}
}
}
return total_sum;
}
')
microbenchmark(x <- B3(Z),
x <- B3_cpp(Z),
unit = "relative",
times = 10)
