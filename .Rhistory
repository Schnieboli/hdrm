M1 <- matrix(rnorm(N*d[1]), d[1], N)
M2 <- matrix(rnorm(N*d[2]), d[2], N)
M3 <- matrix(rnorm(N*d[3]), d[3], N)
M1t <- t(M1)
M2t <- t(M2)
M3t <- t(M3)
B2_intuitiv <- function(X){
S <- 0
N <- dim(X)[2]
for (i in 1:N) {
for(j in 1:N){
if(i != j) S <- S + sum(X[,i]*X[,j])^2
}
}
return(S)
}
