for (int j = i + 1; j < nrows - 1; ++j) {
for (int k = j + 1; k < nrows; ++k) {
row1 = mat(i, _);
row2 = mat(j, _);
row3 = mat(k, _);
total_sum += std::inner_product(row1.begin(), row1.end(), row2.begin(), 0.0) + std::inner_product(row2.begin(), row2.end(), row3.begin(), 0.0) + std::inner_product(row3.begin(), row3.end(), row1.begin(), 0.0);
}
}
}
return total_sum;
}
')
