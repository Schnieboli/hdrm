use_r("Versuch_B2_cpp")
Rcpp::cppFunction("double A2_cpp(const NumericMatrix& mat_i, const NumericMatrix& mat_r){
int n1 = mat_i.nrow();
int n2 = mat_r.nrow();
int d = mat_i.ncol();
double temp = 0.0;
double out = 0.0;
double p1;
double p2;
for(int i = 0; i < n1; ++i){
for(int j = 0; j < n2; ++j){
temp = 0;
for(int k = 0; k < d; ++k){
p1 = mat_i(i,k);
p2 = mat_r(j,k);
temp += p1 * p2;
}
out += pow(temp, 2);
}
}
return out;
}
")
use_test("tests/testthat/test-test-trace_estimators_Sattler.R")
