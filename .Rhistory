Rcpp::cppFunction(' // etwa 10x schneller
double B3_cpp(NumericMatrix mat) {
int nrows = mat.nrow();
int ncols = mat.nrow();
double total_sum = 0.0;
NumericVector row1;
NumericVector row2;
NumericVector row3;
double dp1;
double dp2;
double dp3;
for (int i = 0; i < nrows - 2; ++i) {
for (int j = i + 1; j < nrows - 1; ++j) {
for (int k = j + 1; k < nrows; ++k) {
dp1 = 0;
dp2 = 0;
dp3 = 0;
for(int r = 0; r < ncols, ++r){
dp1 += mat(i,r) * mat(j,r);
dp2 += mat(j,r) * mat(k,r);
dp3 += mat(k,r) * mat(i,r);
}
total_sum += dp1 * dp2 * dp3;
}
}
}
return total_sum;
}
')
Rcpp::cppFunction(' // etwa 10x schneller
double B3_cpp(NumericMatrix mat) {
