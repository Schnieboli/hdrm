A3_intuitiv <- function(X){
nX <- ncol(X)
S <- 0
comb <- combn(nX, 2)
for (l1 in 1:(nX-1)) {
for(l2 in (l1+1):nX){
for(k2 in 1:(nX-1)){
for(k1 in (k2+1):nX){
if(k2 != l1 & k2 != l2 & k1 != l1 & k1 != l2) S <- S + sum((X[, l1] - X[, l2]) * (X[, k1] - X[, k2]))^2
}
}
}
}
return(S / (24 * choose(nX,4)))
}
