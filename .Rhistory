if(missing(formula)){
if(!all(names(data) %in% c("subject","value","factor"))){
N <- length(table(data$subject))
## Anzahl Dimensionen
# ﺣﺙberprﺣﺙfen, ob alle dimensionen gleich oft vorkommen
if(length(unique(table(data$dimension))) == 1){
d <- sum(data$subject == data$subject[1])
}else{
stop("Different number of events for at least one individual")
}
### Matrix bauen
Mat <- matrix(NA, N, d)
for (i in 1:N) {
Mat[i,] <- data$value[data$subject == i][order(data$dimension[data$subject == i])]
}
}else stop("Error: Data should have three columns with names 'value', 'subject' and 'factor'.")
}
