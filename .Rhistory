P2 <- diag(n2) - matrix(1/n2,n2,n2)
Erg1_R <- A1(M1)
Erg1_cpp <- A1_cpp(t(M1))
test_that("A1 == A1_cpp",{
expect_equal(Erg1_cpp, Erg1_R)
})
