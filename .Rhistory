for (int k = j + 1; k < nrows; ++k) {
dp1 = 0;
dp2 = 0;
dp3 = 0;
for(int r = 0; r < ncols; ++r){
dp1 += mat(i,r) * mat(j,r);
dp2 += mat(j,r) * mat(k,r);
dp3 += mat(k,r) * mat(i,r);
}
total_sum += dp1 * dp2 * dp3;
}
}
}
return total_sum;
}
')
B3_intuitiv <- function(X){
N <- ncol(X)
S <- 0
#browser()
for (k in 1:(N-2)) {
for (l in (k+1):(N-1)) {
for (r in (l+1):N) {
S <- S + (sum(X[, k] * X[, l]) * sum(X[, l] * X[, r]) * sum(X[, r] * X[, k]))
}
}
}
return(sum(S))
}
set.seed(1)
N <- 30
d <- 40
X <- matrix(rnorm(30*40), d, N)
B3(X)
B3_intuitiv(X)
B3_cpp(t(X))
